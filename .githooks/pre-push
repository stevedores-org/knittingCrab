#!/bin/bash
# Pre-push hook: Runs local-ci validation before allowing push
# Ensures all changes pass CI checks before reaching GitHub

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo -e "${YELLOW}🔍 Running pre-push CI checks...${NC}"
echo ""

# Check if local-ci is available
if ! command -v local-ci &> /dev/null; then
    echo -e "${YELLOW}⚠️  local-ci not found. Falling back to basic cargo checks.${NC}"
    echo ""

    # Fallback to basic checks
    echo "Running basic checks (fmt, clippy, test)..."

    if ! cargo fmt --all -- --check; then
        echo -e "${RED}❌ Code formatting check failed${NC}"
        echo "Fix with: cargo fmt --all"
        exit 1
    fi

    if ! cargo clippy --all-targets --all-features -- -D warnings; then
        echo -e "${RED}❌ Clippy check failed${NC}"
        exit 1
    fi

    if ! cargo test --all-targets --lib; then
        echo -e "${RED}❌ Tests failed${NC}"
        exit 1
    fi

    echo -e "${GREEN}✅ All checks passed${NC}"
    exit 0
fi

# Use local-ci for validation
if local-ci run; then
    echo ""
    echo -e "${GREEN}✅ All CI checks passed - proceeding with push${NC}"
    exit 0
else
    echo ""
    echo -e "${RED}❌ CI checks failed - push blocked${NC}"
    echo "Fix the errors above and try pushing again."
    exit 1
fi
