#!/bin/bash
set -e

# Pre-commit hook for knittingCrab
# Runs local checks before allowing commits

echo "🔍 Running pre-commit checks..."

# Check formatting
echo "  📝 Checking code formatting..."
cargo fmt --all -- --check || { echo "❌ Formatting check failed"; exit 1; }

# Run clippy
echo "  🔗 Running clippy lints..."
cargo clippy --all-targets --all-features -- -D warnings || { echo "❌ Clippy check failed"; exit 1; }

echo "✅ Pre-commit checks passed"
